@model IEnumerable<ProductionManagementSystem.Models.WorkOrder>
@{
    ViewData["Title"] = "Производственные заказы";
}

<h2 class="mb-4"><i class="bi bi-clipboard-check"></i> Производственные заказы</h2>

<div class="alert alert-info">
    <i class="bi bi-info-circle"></i> 
    Прогресс заказов обновляется автоматически. Производство продолжается даже когда вы на другой странице.
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createOrderModal">
            <i class="bi bi-plus-circle"></i> Создать новый заказ
        </button>
    </div>
    <div>
        <div class="btn-group" role="group">
            <button class="btn btn-outline-secondary filter-btn active" data-filter="all">
                <i class="bi bi-list"></i> Все
            </button>
            <button class="btn btn-outline-warning filter-btn" data-filter="Pending">
                <i class="bi bi-clock"></i> Ожидают
            </button>
            <button class="btn btn-outline-primary filter-btn" data-filter="InProgress">
                <i class="bi bi-play-fill"></i> В работе
            </button>
            <button class="btn btn-outline-info filter-btn" data-filter="Paused">
                <i class="bi bi-pause-fill"></i> На паузе
            </button>
            <button class="btn btn-outline-success filter-btn" data-filter="Completed">
                <i class="bi bi-check-circle"></i> Завершены
            </button>
        </div>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover" id="ordersTable">
        <thead class="table-dark">
            <tr>
                <th>Номер</th>
                <th>Продукт</th>
                <th>Количество</th>
                <th>Статус</th>
                <th>Прогресс</th>
                <th>Линия</th>
                <th>Срок выполнения</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr class="order-row" data-status="@order.Status" data-order-id="@order.Id">
                    <td><strong>#@order.Id</strong></td>
                    <td>@order.Product?.Name</td>
                    <td>@order.Quantity шт.</td>
                    <td>
                        @{
                            string badgeClass = order.Status switch
                            {
                                "Pending" => "bg-warning text-dark",
                                "InProgress" => "bg-primary",
                                "Paused" => "bg-info text-dark",
                                "Completed" => "bg-success",
                                "Cancelled" => "bg-secondary",
                                _ => "bg-light text-dark"
                            };
                            string statusIcon = order.Status switch
                            {
                                "Pending" => "bi-clock",
                                "InProgress" => "bi-play-fill",
                                "Paused" => "bi-pause-fill",
                                "Completed" => "bi-check-circle",
                                "Cancelled" => "bi-x-circle",
                                _ => "bi-question-circle"
                            };
                            string statusText = order.Status switch
                            {
                                "Pending" => "Ожидает",
                                "InProgress" => "В работе",
                                "Paused" => "На паузе",
                                "Completed" => "Завершён",
                                "Cancelled" => "Отменён",
                                _ => order.Status
                            };
                        }
                        <span class="badge @badgeClass status-badge">
                            <i class="bi @statusIcon"></i> @statusText
                        </span>
                    </td>
                    <td>
                        <div class="progress" style="height: 25px;">
                            <div class="progress-bar progress-bar-striped @(order.Status == "InProgress" ? "progress-bar-animated" : "") 
                                        @(order.Status == "Completed" ? "bg-success" : "")" 
                                 role="progressbar" 
                                 style="width: @order.ProgressPercent%;" 
                                 aria-valuenow="@order.ProgressPercent" 
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                                @order.ProgressPercent%
                            </div>
                        </div>
                    </td>
                    <td>
                        @if (order.ProductionLine != null)
                        {
                            <span class="text-muted">
                                <i class="bi bi-gear"></i> @order.ProductionLine.Name
                            </span>
                        }
                        else
                        {
                            <span class="text-muted">
                                <i class="bi bi-question-circle"></i> Не назначена
                            </span>
                        }
                    </td>
                    <td>
                        <small>
                            <i class="bi bi-calendar-check"></i> @order.EstimatedEndDate.ToString("dd.MM.yyyy HH:mm")
                        </small>
                        @if (order.Status == "InProgress" && order.EstimatedEndDate < DateTime.Now)
                        {
                            <br/><span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> Просрочен</span>
                        }
                    </td>
                    <td>
                        <div class="btn-group btn-group-sm">
                            @if (order.Status == "Pending")
                            {
                                <button class="btn btn-success start-order-btn" data-order-id="@order.Id" title="Запустить в производство">
                                    <i class="bi bi-play-fill"></i> Запустить
                                </button>
                                <button class="btn btn-danger cancel-order-btn" data-order-id="@order.Id" title="Отменить заказ">
                                    <i class="bi bi-x-circle"></i> Отменить
                                </button>
                            }
                            else if (order.Status == "InProgress")
                            {
                                <button class="btn btn-warning pause-order-btn" data-order-id="@order.Id" title="Приостановить">
                                    <i class="bi bi-pause-fill"></i> Пауза
                                </button>
                                <button class="btn btn-danger cancel-order-btn" data-order-id="@order.Id" title="Отменить заказ">
                                    <i class="bi bi-x-circle"></i> Отменить
                                </button>
                            }
                            else if (order.Status == "Paused")
                            {
                                <button class="btn btn-success resume-order-btn" data-order-id="@order.Id" title="Возобновить">
                                    <i class="bi bi-play-fill"></i> Возобновить
                                </button>
                                <button class="btn btn-danger cancel-order-btn" data-order-id="@order.Id" title="Отменить заказ">
                                    <i class="bi bi-x-circle"></i> Отменить
                                </button>
                            }
                            <button class="btn btn-info details-order-btn" data-order-id="@order.Id" title="Подробнее">
                                <i class="bi bi-info-circle"></i>
                            </button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- Модальное окно создания заказа -->
<div class="modal fade" id="createOrderModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-plus-circle"></i> Создать новый производственный заказ
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="createOrderForm">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label for="productSelect" class="form-label">Продукт <span class="text-danger">*</span></label>
                            <select class="form-select" id="productSelect" required>
                                <option value="">Выберите продукт...</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="quantityInput" class="form-label">Количество <span class="text-danger">*</span></label>
                            <input type="number" class="form-control" id="quantityInput" required min="1" value="1">
                        </div>
                        <div class="col-md-3">
                            <label for="lineSelect" class="form-label">Производственная линия</label>
                            <select class="form-select" id="lineSelect">
                                <option value="">Автоматический выбор</option>
                            </select>
                        </div>
                    </div>
                    
                    <div id="productInfo" style="display: none;">
                        <hr>
                        <h6><i class="bi bi-info-circle"></i> Информация о продукте:</h6>
                        <div class="row">
                            <div class="col-md-4">
                                <small class="text-muted">Время производства:</small><br>
                                <strong><span id="infoProdTime">-</span> мин/шт</strong>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted">Общее время:</small><br>
                                <strong><span id="infoTotalTime">-</span></strong>
                            </div>
                            <div class="col-md-4">
                                <small class="text-muted">Завершение:</small><br>
                                <strong><span id="infoEndDate">-</span></strong>
                            </div>
                        </div>
                    </div>
                    
                    <div id="materialCheck" style="display: none;">
                        <hr>
                        <h6><i class="bi bi-box-seam"></i> Проверка материалов:</h6>
                        <div id="materialCheckResult"></div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Отмена
                </button>
                <button type="button" class="btn btn-primary" id="saveOrderBtn" disabled>
                    <i class="bi bi-check-circle"></i> Создать заказ
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Модальное окно деталей заказа -->
<div class="modal fade" id="orderDetailsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title">
                    <i class="bi bi-info-circle"></i> Детали заказа #<span id="detailOrderId">-</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="orderDetailsContent">
                    <p class="text-center">
                        <div class="spinner-border text-info" role="status">
                            <span class="visually-hidden">Загрузка...</span>
                        </div>
                    </p>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Закрыть
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ==================== АВТООБНОВЛЕНИЕ ПРОГРЕССА ====================
        let refreshInterval;
        let currentFilter = 'all';

        function startAutoRefresh() {
            refreshInterval = setInterval(updateOrdersProgress, 2000);
        }

        function stopAutoRefresh() {
            if (refreshInterval) {
                clearInterval(refreshInterval);
            }
        }

        async function updateOrdersProgress() {
            try {
                const response = await fetch('/api/orders');
                if (!response.ok) return;
                
                const orders = await response.json();
                
                orders.forEach(order => {
                    const row = document.querySelector('tr[data-order-id="' + order.id + '"]');
                    if (!row) return;
                    
                    row.setAttribute('data-status', order.status);
                    
                    const progressBar = row.querySelector('.progress-bar');
                    if (progressBar) {
                        progressBar.style.width = order.progressPercent + '%';
                        progressBar.setAttribute('aria-valuenow', order.progressPercent);
                        progressBar.textContent = order.progressPercent + '%';
                        
                        if (order.status === 'InProgress') {
                            progressBar.classList.add('progress-bar-animated');
                            progressBar.classList.remove('bg-success');
                        } else if (order.status === 'Completed') {
                            progressBar.classList.remove('progress-bar-animated');
                            progressBar.classList.add('bg-success');
                        } else {
                            progressBar.classList.remove('progress-bar-animated');
                        }
                    }
                    
                    const statusCell = row.querySelector('td:nth-child(4) .badge');
                    if (statusCell) {
                        statusCell.innerHTML = '<i class="bi ' + getStatusIcon(order.status) + '"></i> ' + getStatusText(order.status);
                        statusCell.className = 'badge ' + getStatusBadgeClass(order.status);
                    }
                    
                    updateActionButtons(row, order);
                    applyFilterToRow(row, currentFilter);
                });
            } catch (error) {
                console.error('Error updating orders:', error);
            }
        }

        function updateActionButtons(row, order) {
            const actionsCell = row.querySelector('td:last-child .btn-group');
            if (!actionsCell) return;
            
            let buttonsHtml = '';
            
            switch(order.status) {
                case 'Pending':
                    buttonsHtml = `
                        <button class="btn btn-success btn-sm start-order-btn" data-order-id="${order.id}" title="Запустить">
                            <i class="bi bi-play-fill"></i> Запустить
                        </button>
                        <button class="btn btn-danger btn-sm cancel-order-btn" data-order-id="${order.id}" title="Отменить">
                            <i class="bi bi-x-circle"></i> Отменить
                        </button>
                    `;
                    break;
                case 'InProgress':
                    buttonsHtml = `
                        <button class="btn btn-warning btn-sm pause-order-btn" data-order-id="${order.id}" title="Пауза">
                            <i class="bi bi-pause-fill"></i> Пауза
                        </button>
                        <button class="btn btn-danger btn-sm cancel-order-btn" data-order-id="${order.id}" title="Отменить">
                            <i class="bi bi-x-circle"></i> Отменить
                        </button>
                    `;
                    break;
                case 'Paused':
                    buttonsHtml = `
                        <button class="btn btn-success btn-sm resume-order-btn" data-order-id="${order.id}" title="Возобновить">
                            <i class="bi bi-play-fill"></i> Возобновить
                        </button>
                        <button class="btn btn-danger btn-sm cancel-order-btn" data-order-id="${order.id}" title="Отменить">
                            <i class="bi bi-x-circle"></i> Отменить
                        </button>
                    `;
                    break;
                default:
                    buttonsHtml = '';
            }
            
            buttonsHtml += `
                <button class="btn btn-info btn-sm details-order-btn" data-order-id="${order.id}" title="Подробнее">
                    <i class="bi bi-info-circle"></i>
                </button>
            `;
            
            actionsCell.innerHTML = buttonsHtml;
            attachButtonEvents(actionsCell);
        }

        function getStatusText(status) {
            const statusMap = {
                'Pending': 'Ожидает',
                'InProgress': 'В работе',
                'Paused': 'На паузе',
                'Completed': 'Завершён',
                'Cancelled': 'Отменён'
            };
            return statusMap[status] || status;
        }

        function getStatusIcon(status) {
            const iconMap = {
                'Pending': 'bi-clock',
                'InProgress': 'bi-play-fill',
                'Paused': 'bi-pause-fill',
                'Completed': 'bi-check-circle',
                'Cancelled': 'bi-x-circle'
            };
            return iconMap[status] || 'bi-question-circle';
        }

        function getStatusBadgeClass(status) {
            const classMap = {
                'Pending': 'bg-warning text-dark',
                'InProgress': 'bg-primary',
                'Paused': 'bg-info text-dark',
                'Completed': 'bg-success',
                'Cancelled': 'bg-secondary'
            };
            return classMap[status] || 'bg-light text-dark';
        }

        // ==================== ФИЛЬТРАЦИЯ ====================
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                
                currentFilter = this.dataset.filter;
                applyFilter(currentFilter);
            });
        });

        function applyFilter(filter) {
            document.querySelectorAll('.order-row').forEach(row => {
                applyFilterToRow(row, filter);
            });
        }

        function applyFilterToRow(row, filter) {
            const status = row.getAttribute('data-status');
            if (filter === 'all' || status === filter) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        }

        // ==================== ДЕЙСТВИЯ С ЗАКАЗАМИ ====================
        function attachButtonEvents(container) {
            container.querySelectorAll('.start-order-btn').forEach(btn => {
                btn.addEventListener('click', startOrder);
            });
            
            container.querySelectorAll('.pause-order-btn').forEach(btn => {
                btn.addEventListener('click', pauseOrder);
            });
            
            container.querySelectorAll('.resume-order-btn').forEach(btn => {
                btn.addEventListener('click', resumeOrder);
            });
            
            container.querySelectorAll('.cancel-order-btn').forEach(btn => {
                btn.addEventListener('click', cancelOrder);
            });
            
            container.querySelectorAll('.details-order-btn').forEach(btn => {
                btn.addEventListener('click', showOrderDetails);
            });
        }

        async function startOrder(e) {
            const orderId = e.target.closest('button').dataset.orderId;
            if (!confirm('Запустить заказ в производство?')) return;
            
            try {
                const response = await fetch('/api/orders/' + orderId + '/start', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    const result = await response.json();
                    alert(result.message || 'Заказ запущен!');
                    await updateOrdersProgress();
                } else {
                    const error = await response.json();
                    alert(error.message || 'Ошибка при запуске заказа');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Ошибка при запуске заказа');
            }
        }

        async function pauseOrder(e) {
            const orderId = e.target.closest('button').dataset.orderId;
            if (!confirm('Поставить заказ на паузу? Производство остановится.')) return;
            
            try {
                const response = await fetch('/api/orders/' + orderId + '/pause', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    const result = await response.json();
                    alert(result.message || 'Заказ приостановлен');
                    await updateOrdersProgress();
                } else {
                    const error = await response.json();
                    alert(error.message || 'Ошибка при паузе заказа');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Ошибка при паузе заказа');
            }
        }

        async function resumeOrder(e) {
            const orderId = e.target.closest('button').dataset.orderId;
            if (!confirm('Возобновить производство?')) return;
            
            try {
                const response = await fetch('/api/orders/' + orderId + '/resume', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    const result = await response.json();
                    alert(result.message || 'Производство возобновлено');
                    await updateOrdersProgress();
                } else {
                    const error = await response.json();
                    alert(error.message || 'Ошибка при возобновлении заказа');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Ошибка при возобновлении заказа');
            }
        }

        async function cancelOrder(e) {
            const orderId = e.target.closest('button').dataset.orderId;
            if (!confirm('Вы уверены, что хотите отменить заказ? Это действие нельзя отменить.')) return;
            
            try {
                const response = await fetch('/api/orders/' + orderId + '/cancel', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' }
                });
                
                if (response.ok) {
                    const result = await response.json();
                    alert(result.message || 'Заказ отменён');
                    await updateOrdersProgress();
                } else {
                    const error = await response.json();
                    alert(error.message || 'Ошибка при отмене заказа');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Ошибка при отмене заказа');
            }
        }

        async function showOrderDetails(e) {
            const orderId = e.target.closest('button').dataset.orderId;
            
            try {
                const response = await fetch('/api/orders/' + orderId + '/details');
                if (!response.ok) {
                    alert('Ошибка при загрузке деталей заказа');
                    return;
                }
                
                const order = await response.json();
                
                document.getElementById('detailOrderId').textContent = order.id;
                
                let html = `
                    <div class="row">
                        <div class="col-md-6">
                            <p><strong><i class="bi bi-hammer"></i> Продукт:</strong> ${order.productName}</p>
                            <p><strong><i class="bi bi-stack"></i> Количество:</strong> ${order.quantity} шт.</p>
                            <p><strong><i class="bi bi-flag"></i> Статус:</strong> <span class="badge ${getStatusBadgeClass(order.status)}"><i class="bi ${getStatusIcon(order.status)}"></i> ${getStatusText(order.status)}</span></p>
                            <p><strong><i class="bi bi-graph-up"></i> Прогресс:</strong> ${order.progressPercent}%</p>
                        </div>
                        <div class="col-md-6">
                            <p><strong><i class="bi bi-calendar"></i> Дата начала:</strong> ${new Date(order.startDate).toLocaleString()}</p>
                            <p><strong><i class="bi bi-calendar-check"></i> Окончание:</strong> ${new Date(order.estimatedEndDate).toLocaleString()}</p>
                            <p><strong><i class="bi bi-gear"></i> Линия:</strong> ${order.productionLineName || 'Не назначена'}</p>
                            ${order.productionLineEfficiency ? `<p><strong><i class="bi bi-speedometer2"></i> Эффективность:</strong> ${order.productionLineEfficiency}</p>` : ''}
                        </div>
                    </div>
                    <hr>
                    <h6><i class="bi bi-box-seam"></i> Необходимые материалы:</h6>
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Материал</th>
                                <th>Требуется</th>
                                <th>В наличии</th>
                                <th>Статус</th>
                            </tr>
                        </thead>
                        <tbody>
                `;
                
                order.materials.forEach(m => {
                    const enough = m.availableQuantity >= m.totalRequired;
                    html += `
                        <tr class="${enough ? 'table-success' : 'table-danger'}">
                            <td>${m.materialName}</td>
                            <td>${m.totalRequired} ${m.unit}</td>
                            <td>${m.availableQuantity} ${m.unit}</td>
                            <td>${enough ? '<i class="bi bi-check-circle text-success"></i> Достаточно' : '<i class="bi bi-x-circle text-danger"></i> Недостаточно'}</td>
                        </tr>
                    `;
                });
                
                html += '</tbody></table>';
                
                document.getElementById('orderDetailsContent').innerHTML = html;
                
                new bootstrap.Modal(document.getElementById('orderDetailsModal')).show();
            } catch (error) {
                console.error('Error:', error);
                alert('Ошибка при загрузке деталей');
            }
        }

        // ==================== СОЗДАНИЕ ЗАКАЗА ====================
        let productsData = [];

        document.addEventListener('DOMContentLoaded', async function() {
            await loadProducts();
            await loadAvailableLines();
            
            document.querySelectorAll('.btn-group').forEach(group => {
                attachButtonEvents(group);
            });
            
            startAutoRefresh();
            
            document.getElementById('productSelect').addEventListener('change', onProductChange);
            document.getElementById('quantityInput').addEventListener('input', onProductChange);
            document.getElementById('saveOrderBtn').addEventListener('click', createOrder);
        });

        window.addEventListener('beforeunload', function() {
            stopAutoRefresh();
        });

        async function loadProducts() {
            try {
                const response = await fetch('/api/products');
                const products = await response.json();
                productsData = products;
                
                const select = document.getElementById('productSelect');
                select.innerHTML = '<option value="">Выберите продукт...</option>';
                products.forEach(product => {
                    const option = document.createElement('option');
                    option.value = product.id;
                    option.textContent = product.name + ' (' + product.productionTimePerUnit + ' мин/шт)';
                    option.dataset.prodTime = product.productionTimePerUnit;
                    option.dataset.category = product.category || '';
                    select.appendChild(option);
                });
            } catch (error) {
                console.error('Error loading products:', error);
            }
        }

        async function loadAvailableLines() {
            try {
                const response = await fetch('/api/lines?available=true');
                const lines = await response.json();
                
                const select = document.getElementById('lineSelect');
                select.innerHTML = '<option value="">Автоматический выбор</option>';
                lines.forEach(line => {
                    const option = document.createElement('option');
                    option.value = line.id;
                    option.textContent = line.name + ' (КПД: ' + line.efficiencyFactor + ')';
                    select.appendChild(option);
                });
            } catch (error) {
                console.error('Error loading lines:', error);
            }
        }

        function onProductChange() {
            const productSelect = document.getElementById('productSelect');
            const quantity = parseInt(document.getElementById('quantityInput').value) || 0;
            const selectedOption = productSelect.options[productSelect.selectedIndex];
            const prodTime = selectedOption.dataset?.prodTime;
            
            const productInfo = document.getElementById('productInfo');
            const materialCheck = document.getElementById('materialCheck');
            const saveBtn = document.getElementById('saveOrderBtn');
            
            if (prodTime && quantity > 0) {
                productInfo.style.display = 'block';
                materialCheck.style.display = 'block';
                saveBtn.disabled = false;
                
                const totalMinutes = quantity * parseInt(prodTime);
                const hours = Math.floor(totalMinutes / 60);
                const minutes = totalMinutes % 60;
                const endDate = new Date(Date.now() + totalMinutes * 60000);
                
                document.getElementById('infoProdTime').textContent = prodTime;
                document.getElementById('infoTotalTime').textContent = hours + ' ч ' + minutes + ' мин';
                document.getElementById('infoEndDate').textContent = endDate.toLocaleString();
                
                checkMaterials(selectedOption.value, quantity);
            } else {
                productInfo.style.display = 'none';
                materialCheck.style.display = 'none';
                saveBtn.disabled = true;
            }
        }

        async function checkMaterials(productId, quantity) {
            try {
                const response = await fetch('/api/products/' + productId + '/materials');
                if (!response.ok) {
                    document.getElementById('materialCheckResult').innerHTML = '<div class="alert alert-warning"><i class="bi bi-exclamation-triangle"></i> Нет данных о материалах</div>';
                    return;
                }
                
                const materials = await response.json();
                if (!materials.length) {
                    document.getElementById('materialCheckResult').innerHTML = '<div class="alert alert-info"><i class="bi bi-info-circle"></i> Для этого продукта не указаны материалы</div>';
                    return;
                }
                
                let html = '<ul class="list-group">';
                let allAvailable = true;
                
                materials.forEach(m => {
                    const totalNeeded = m.quantityNeeded * quantity;
                    const available = m.availableQuantity || 0;
                    const enough = available >= totalNeeded;
                    if (!enough) allAvailable = false;
                    
                    html += `
                        <li class="list-group-item ${enough ? 'list-group-item-success' : 'list-group-item-danger'}">
                            <strong>${m.name}</strong>: 
                            требуется ${totalNeeded} ${m.unitOfMeasure} 
                            (в наличии: ${available} ${m.unitOfMeasure})
                            ${enough ? '<i class="bi bi-check-circle text-success"></i>' : '<i class="bi bi-x-circle text-danger"></i> НЕДОСТАТОЧНО!'}
                        </li>
                    `;
                });
                
                html += '</ul>';
                
                if (!allAvailable) {
                    html += '<div class="alert alert-danger mt-2"><i class="bi bi-exclamation-circle"></i> Недостаточно материалов для выполнения заказа!</div>';
                    document.getElementById('saveOrderBtn').disabled = true;
                } else {
                    html += '<div class="alert alert-success mt-2"><i class="bi bi-check-circle"></i> Все материалы в наличии</div>';
                    document.getElementById('saveOrderBtn').disabled = false;
                }
                
                document.getElementById('materialCheckResult').innerHTML = html;
            } catch (error) {
                console.error('Error checking materials:', error);
                document.getElementById('materialCheckResult').innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-circle"></i> Ошибка при проверке материалов</div>';
            }
        }

        async function createOrder() {
            const productId = parseInt(document.getElementById('productSelect').value);
            const quantity = parseInt(document.getElementById('quantityInput').value);
            const lineId = document.getElementById('lineSelect').value;
            
            if (!productId || !quantity) {
                alert('Заполните обязательные поля');
                return;
            }
            
            const orderData = {
                productId: productId,
                quantity: quantity,
                lineId: lineId ? parseInt(lineId) : null
            };
            
            try {
                const response = await fetch('/api/orders', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(orderData)
                });
                
                if (response.ok) {
                    const result = await response.json();
                    alert('Заказ #' + result.id + ' создан успешно!');
                    
                    bootstrap.Modal.getInstance(document.getElementById('createOrderModal')).hide();
                    await updateOrdersProgress();
                    setTimeout(() => location.reload(), 500);
                } else {
                    const error = await response.json();
                    alert(error.message || 'Ошибка при создании заказа');
                }
            } catch (error) {
                console.error('Error:', error);
                alert('Ошибка при создании заказа');
            }
        }
    </script>
}