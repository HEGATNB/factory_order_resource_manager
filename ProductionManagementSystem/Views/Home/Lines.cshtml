@model IEnumerable<ProductionManagementSystem.Models.ProductionLine>
@{
    ViewData["Title"] = "Интерактивная панель линий";
}

<h2 class="mb-4"><i class="bi bi-gear"></i> Интерактивная панель производственных линий</h2>
<div class="row" id="linesContainer">
    @foreach (var line in Model)
    {
        <div class="col-md-6 mb-4">
            <div class="card" id="line-@line.Id">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">@line.Name</h5>
                    <span class="badge @(line.Status == "Active" ? "bg-success" : "bg-danger") status-badge">
                        <i class="bi @(line.Status == "Active" ? "bi-play-fill" : "bi-stop-fill")"></i>
                        @(line.Status == "Active" ? "Работает" : "Остановлена")
                    </span>
                </div>
                <div class="card-body">
                    <div class="mb-3">
                        <strong><i class="bi bi-speedometer2"></i> Коэффициент эффективности:</strong> 
                        <span class="efficiency-value">@line.EfficiencyFactor.ToString("F1")</span>
                        <div class="mt-2">
                            <input type="range" class="form-range efficiency-slider" 
                                   min="0.5" max="2.0" step="0.1" 
                                   value="@line.EfficiencyFactor.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)"
                                   data-line-id="@line.Id">
                            <div class="d-flex justify-content-between">
                                <small>0.5 (медленно)</small>
                                <small>1.0 (норма)</small>
                                <small>2.0 (быстро)</small>
                            </div>
                        </div>
                    </div>
                    
                    @if (line.CurrentWorkOrder != null)
                    {
                        <div class="alert alert-info mb-3">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong><i class="bi bi-clipboard-check"></i> Текущий заказ:</strong> #@line.CurrentWorkOrder.Id<br>
                                    <strong><i class="bi bi-hammer"></i> Продукт:</strong> @line.CurrentWorkOrder.Product?.Name<br>
                                    <strong><i class="bi bi-stack"></i> Кол-во:</strong> @line.CurrentWorkOrder.Quantity шт.<br>
                                    <strong><i class="bi bi-flag"></i> Статус:</strong> @line.CurrentWorkOrder.Status
                                </div>
                                <div>
                                    <span class="badge @(line.CurrentWorkOrder.Status == "Paused" ? "bg-warning" : "bg-info")">
                                        @if (line.CurrentWorkOrder.Status == "Paused")
                                        {
                                            <i class="bi bi-pause-fill"></i> @:На паузе
                                        }
                                        else
                                        {
                                            <i class="bi bi-play-fill"></i> @:В работе
                                        }
                                    </span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="progress mb-3" style="height: 30px;">
                            <div class="progress-bar progress-bar-striped @(line.CurrentWorkOrder.Status != "Paused" ? "progress-bar-animated" : "")" 
                                 role="progressbar" 
                                 style="width: @line.CurrentWorkOrder.ProgressPercent%;" 
                                 aria-valuenow="@line.CurrentWorkOrder.ProgressPercent" 
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                                @line.CurrentWorkOrder.ProgressPercent%
                            </div>
                        </div>
                        
                        <div class="d-flex gap-2 mb-3">
                            @if (line.CurrentWorkOrder.Status == "Paused")
                            {
                                <button class="btn btn-success flex-grow-1 resume-order-btn" 
                                        data-order-id="@line.CurrentWorkOrder.Id">
                                    <i class="bi bi-play-fill"></i> Возобновить заказ
                                </button>
                            }
                            else if (line.CurrentWorkOrder.Status == "InProgress")
                            {
                                <button class="btn btn-warning flex-grow-1 pause-order-btn" 
                                        data-order-id="@line.CurrentWorkOrder.Id">
                                    <i class="bi bi-pause-fill"></i> Поставить на паузу
                                </button>
                            }
                            <button class="btn btn-outline-danger remove-order-btn" 
                                    data-order-id="@line.CurrentWorkOrder.Id"
                                    data-line-id="@line.Id"
                                    title="Убрать заказ с линии">
                                <i class="bi bi-x-circle"></i> Убрать заказ
                            </button>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mb-3">
                            <i class="bi bi-exclamation-triangle"></i> 
                            Нет активного заказа на линии
                        </div>
                        
                        @if (line.Status == "Active")
                        {
                            <div class="mb-3">
                                <button class="btn btn-primary w-100 assign-order-btn" 
                                        data-line-id="@line.Id"
                                        data-line-name="@line.Name">
                                    <i class="bi bi-clipboard-plus"></i> Назначить заказ на линию
                                </button>
                            </div>
                        }
                    }

                    <div class="btn-group w-100 mt-3" role="group">
                        @if (line.Status == "Active")
                        {
                            <button class="btn btn-outline-danger stop-line-btn" data-line-id="@line.Id">
                                <i class="bi bi-stop-fill"></i> Остановить линию
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-outline-success start-line-btn" data-line-id="@line.Id">
                                <i class="bi bi-play-fill"></i> Запустить линию
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Модальное окно выбора заказа для назначения на линию -->
<div class="modal fade" id="assignOrderModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title">
                    <i class="bi bi-clipboard-plus"></i> Назначить заказ на линию: <span id="assignLineName">-</span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" class="form-control" id="orderSearchInput" 
                               placeholder="Поиск заказа по номеру или продукту...">
                    </div>
                </div>
                
                <div id="availableOrdersList">
                    <div class="text-center">
                        <div class="spinner-border" role="status">
                            <span class="visually-hidden">Загрузка...</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-circle"></i> Отмена
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ==================== АВТООБНОВЛЕНИЕ ====================
        let autoRefreshInterval;

        function startAutoRefresh() {
            autoRefreshInterval = setInterval(updateAllProgress, 2000);
        }

        function stopAutoRefresh() {
            if (autoRefreshInterval) {
                clearInterval(autoRefreshInterval);
            }
        }

        async function updateAllProgress() {
            try {
                const response = await fetch('/api/lines');
                if (!response.ok) return;
                
                const lines = await response.json();
                
                lines.forEach(line => {
                    updateLineProgress(line.id, line.currentProgress, line.status, line.currentWorkOrderId);
                });
            } catch (error) {
                console.error('Error updating progress:', error);
            }
        }

        function updateLineProgress(lineId, progress, lineStatus, currentWorkOrderId) {
            const card = document.getElementById('line-' + lineId);
            if (!card) return;
            
            const progressBar = card.querySelector('.progress-bar');
            if (progressBar && progress !== null && progress !== undefined) {
                progressBar.style.width = progress + '%';
                progressBar.setAttribute('aria-valuenow', progress);
                progressBar.textContent = progress + '%';
                
                if (currentWorkOrderId) {
                    progressBar.classList.add('progress-bar-animated');
                } else {
                    progressBar.classList.remove('progress-bar-animated');
                }
            }
            
            const statusBadge = card.querySelector('.status-badge');
            if (statusBadge) {
                if (lineStatus === 'Active') {
                    statusBadge.className = 'badge bg-success status-badge';
                    statusBadge.innerHTML = '<i class="bi bi-play-fill"></i> Работает';
                } else {
                    statusBadge.className = 'badge bg-danger status-badge';
                    statusBadge.innerHTML = '<i class="bi bi-stop-fill"></i> Остановлена';
                }
            }
        }

        // ==================== НАЗНАЧЕНИЕ ЗАКАЗА НА ЛИНИЮ ====================
        let selectedLineId = null;
        let availableOrders = [];

        document.querySelectorAll('.assign-order-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                selectedLineId = this.dataset.lineId;
                const lineName = this.dataset.lineName;
                
                document.getElementById('assignLineName').textContent = lineName;
                document.getElementById('orderSearchInput').value = '';
                
                await loadAvailableOrders();
                
                new bootstrap.Modal(document.getElementById('assignOrderModal')).show();
            });
        });

        async function loadAvailableOrders() {
            const listContainer = document.getElementById('availableOrdersList');
            listContainer.innerHTML = '<div class="text-center"><div class="spinner-border" role="status"><span class="visually-hidden">Загрузка...</span></div></div>';
            
            try {
                const response = await fetch('/api/orders?status=Pending,Paused');
                if (!response.ok) {
                    listContainer.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-circle"></i> Ошибка загрузки заказов</div>';
                    return;
                }
                
                const allOrders = await response.json();
                availableOrders = allOrders.filter(order => order.productionLineId === null || order.productionLineId === undefined);
                
                renderOrdersList(availableOrders);
            } catch (error) {
                console.error('Error loading orders:', error);
                listContainer.innerHTML = '<div class="alert alert-danger"><i class="bi bi-exclamation-circle"></i> Ошибка загрузки заказов</div>';
            }
        }

        function renderOrdersList(orders) {
            const listContainer = document.getElementById('availableOrdersList');
            
            if (orders.length === 0) {
                listContainer.innerHTML = `
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> 
                        Нет доступных заказов для назначения. 
                        Все активные заказы уже распределены по линиям или завершены.
                        <br><br>
                        <a href="/Home/Orders" class="btn btn-sm btn-primary"><i class="bi bi-plus-circle"></i> Создать новый заказ</a>
                    </div>
                `;
                return;
            }
            
            let html = '<div class="list-group">';
            
            orders.forEach(order => {
                const statusBadge = order.status === 'Pending' 
                    ? '<span class="badge bg-warning text-dark"><i class="bi bi-clock"></i> Ожидает</span>' 
                    : '<span class="badge bg-info text-dark"><i class="bi bi-pause-fill"></i> На паузе</span>';
                
                const startDate = new Date(order.startDate).toLocaleString();
                const endDate = new Date(order.estimatedEndDate).toLocaleString();
                
                html += `
                    <div class="list-group-item list-group-item-action order-list-item" 
                         data-order-id="${order.id}"
                         onclick="selectOrderForLine(${order.id})">
                        <div class="d-flex w-100 justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1"><i class="bi bi-clipboard-check"></i> Заказ #${order.id} - ${order.productName}</h6>
                                <small class="text-muted">
                                    <i class="bi bi-stack"></i> Кол-во: ${order.quantity} шт. | 
                                    <i class="bi bi-graph-up"></i> Прогресс: ${order.progressPercent}% |
                                    <i class="bi bi-calendar"></i> Создан: ${startDate}
                                </small>
                            </div>
                            <div class="text-end">
                                ${statusBadge}
                                <br>
                                <small class="text-muted"><i class="bi bi-calendar-check"></i> до ${endDate}</small>
                            </div>
                        </div>
                    </div>
                `;
            });
            
            html += '</div>';
            html += '<small class="text-muted mt-2"><i class="bi bi-list"></i> Найдено заказов: ' + orders.length + '</small>';
            
            listContainer.innerHTML = html;
        }

        document.getElementById('orderSearchInput').addEventListener('input', function() {
            const searchText = this.value.toLowerCase();
            
            if (!searchText) {
                renderOrdersList(availableOrders);
                return;
            }
            
            const filtered = availableOrders.filter(order => 
                order.id.toString().includes(searchText) ||
                (order.productName && order.productName.toLowerCase().includes(searchText))
            );
            
            renderOrdersList(filtered);
        });

        async function selectOrderForLine(orderId) {
            if (!confirm('Назначить заказ #' + orderId + ' на выбранную линию?')) return;
            
            try {
                const response = await fetch('/api/orders/' + orderId + '/changeline', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ newLineId: parseInt(selectedLineId) })
                });
                
                if (response.ok) {
                    const result = await response.json();
                    bootstrap.Modal.getInstance(document.getElementById('assignOrderModal')).hide();
                    alert(result.message || 'Заказ #' + orderId + ' назначен на линию');
                    location.reload();
                } else {
                    const error = await response.json();
                    alert(error.message || 'Ошибка при назначении заказа');
                }
            } catch (error) {
                console.error('Error assigning order:', error);
                alert('Ошибка при назначении заказа');
            }
        }

        // ==================== УБРАТЬ ЗАКАЗ С ЛИНИИ ====================
        document.querySelectorAll('.remove-order-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const orderId = this.dataset.orderId;
                const lineId = this.dataset.lineId;
                
                if (!confirm('Убрать заказ #' + orderId + ' с линии? Заказ вернется в статус ожидания.')) return;
                
                try {
                    const response = await fetch('/api/orders/' + orderId + '/removeline', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' }
                    });
                    
                    if (response.ok) {
                        alert('Заказ #' + orderId + ' убран с линии');
                        location.reload();
                    } else {
                        const error = await response.json();
                        alert(error.message || 'Ошибка при удалении заказа с линии');
                    }
                } catch (error) {
                    console.error('Error removing order:', error);
                    alert('Ошибка при удалении заказа с линии');
                }
            });
        });

        // ==================== СЛАЙДЕРЫ ЭФФЕКТИВНОСТИ ====================
        document.querySelectorAll('.efficiency-slider').forEach(slider => {
            slider.addEventListener('change', async function() {
                const lineId = this.dataset.lineId;
                const efficiency = parseFloat(this.value).toFixed(1);
                
                try {
                    const response = await fetch('/api/lines/' + lineId + '/efficiency', {
                        method: 'PUT',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ efficiencyFactor: parseFloat(efficiency) })
                    });
                    
                    if (response.ok) {
                        this.closest('.card-body').querySelector('.efficiency-value').textContent = efficiency;
                    }
                } catch (error) {
                    console.error('Error updating efficiency:', error);
                }
            });
        });

        // ==================== ПАУЗА/ВОЗОБНОВЛЕНИЕ ЗАКАЗА ====================
        document.querySelectorAll('.pause-order-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const orderId = this.dataset.orderId;
                if (!confirm('Поставить заказ на паузу?')) return;
                
                try {
                    const response = await fetch('/api/orders/' + orderId + '/pause', { method: 'PUT' });
                    if (response.ok) {
                        location.reload();
                    } else {
                        const error = await response.json();
                        alert(error.message);
                    }
                } catch (error) {
                    console.error('Error pausing order:', error);
                }
            });
        });

        document.querySelectorAll('.resume-order-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const orderId = this.dataset.orderId;
                if (!confirm('Возобновить производство?')) return;
                
                try {
                    const response = await fetch('/api/orders/' + orderId + '/resume', { method: 'PUT' });
                    if (response.ok) {
                        location.reload();
                    } else {
                        const error = await response.json();
                        alert(error.message);
                    }
                } catch (error) {
                    console.error('Error resuming order:', error);
                }
            });
        });

        // ==================== УПРАВЛЕНИЕ ЛИНИЯМИ ====================
        document.querySelectorAll('.stop-line-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const lineId = this.dataset.lineId;
                if (!confirm('Остановить линию?')) return;
                
                await fetch('/api/lines/' + lineId + '/status', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'Stopped' })
                });
                location.reload();
            });
        });

        document.querySelectorAll('.start-line-btn').forEach(btn => {
            btn.addEventListener('click', async function() {
                const lineId = this.dataset.lineId;
                
                await fetch('/api/lines/' + lineId + '/status', {
                    method: 'PUT',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ status: 'Active' })
                });
                location.reload();
            });
        });

        // ==================== ИНИЦИАЛИЗАЦИЯ ====================
        document.addEventListener('DOMContentLoaded', function() {
            startAutoRefresh();
        });

        window.addEventListener('beforeunload', function() {
            stopAutoRefresh();
        });
    </script>
}